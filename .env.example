# Database
POSTGRES_USER=procurement
POSTGRES_PASSWORD=procurement
POSTGRES_DB=procurement
DATABASE_URL=postgresql+asyncpg://procurement:procurement@postgres:5432/procurement

# Redis
REDIS_URL=redis://redis:6379

# Auth
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenRouter
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# Tavily (web search for supplier discovery)
TAVILY_API_KEY=tvly-...

# Public supplier self-registration (required header X-Registration-Token on POST /public/supplier-registration)
PUBLIC_SUPPLIER_REGISTRATION_TOKEN=change-me-long-random-string

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPPLIER_REGISTRATION_TOKEN=change-me-long-random-string
